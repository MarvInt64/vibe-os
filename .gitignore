# ---- Build output --------------------------------------------------------
build/

# ---- Generated disk and ISO images ---------------------------------------
# vibeos-disk.img is large (32 MB), user-specific, and gets modified at
# runtime by the OS itself — no point committing it.
vibeos-disk.img
*.iso

# ---- Object / dependency files that might escape build/ ------------------
*.o
*.d
*.a
*.elf

# ---- Rust build artefacts ------------------------------------------------
target/
Cargo.lock

# ---- macOS metadata ------------------------------------------------------
.DS_Store
**/.DS_Store

# ---- Python cache --------------------------------------------------------
__pycache__/
*.pyc
*.pyo

# ---- Editor / IDE --------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
compile_commands.json

# ---- Claude Code session data --------------------------------------------
.claude/
.claw/
.claw-todos.json
.codesharp/

# ---- QEMU / sandbox scratch dirs -----------------------------------------
.sandbox-home/
.sandbox-tmp/

# ---- Backup / scratch files ----------------------------------------------
Makefile.backup
Makefile.disk
test_wm.sh
test_wm2.sh
test_term.sh

# ---- Screenshots / design reference images (local only) -----------------
vision_desktop*.png
vision_desktop*.jpg
*.screenshot.*

# ---- Serial / run logs (runtime, not source) ----------------------------
serial.log
*.log

# ---- Conductor / session artefacts --------------------------------------
conductor/

# ---- Third-party source trees that are NOT submodules -------------------
third_party/quickjs/
.cache

# ---- One-off bugfix scripts ----------------------------------------------
fix_arch.py
fix_bkl.py
fix_process.py

# ---- QEMU output artifact ------------------------------------------------
qemu_out.txt

# ---- Scratch files -------------------------------------------------------
scratch/

# ---- Embedded TCC repo (managed separately) ------------------------------
third_party/tcc/

# ---- Obsolete stubs (DOOM now runs natively on arm64) --------------------
user/arm64/stub_doom.c
