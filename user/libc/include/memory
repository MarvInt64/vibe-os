#ifndef VIBEOS_MEMORY
#define VIBEOS_MEMORY

/* Freestanding <memory> subset for VibeOS userspace: addressof, default_delete,
 * unique_ptr (single object + array specialisation) and make_unique.  No
 * exceptions, no shared_ptr yet — enough for RAII ownership in real C++ apps
 * and as a stepping stone toward running larger C++ programs on VibeOS. */

#include <cstddef>
#include <type_traits>
#include <utility>

namespace std {

/* --- addressof ----------------------------------------------------------- */
template <typename T>
T *addressof(T &arg) noexcept {
    return __builtin_addressof(arg);
}
template <typename T>
const T *addressof(const T &&) = delete;

/* --- default_delete ------------------------------------------------------ */
template <typename T>
struct default_delete {
    constexpr default_delete() noexcept = default;
    template <typename U>
    default_delete(const default_delete<U> &) noexcept {}
    void operator()(T *p) const { delete p; }
};

template <typename T>
struct default_delete<T[]> {
    constexpr default_delete() noexcept = default;
    void operator()(T *p) const { delete[] p; }
};

/* --- unique_ptr (single object) ------------------------------------------ */
template <typename T, typename D = default_delete<T>>
class unique_ptr {
public:
    using pointer      = T *;
    using element_type = T;
    using deleter_type = D;

    constexpr unique_ptr() noexcept : ptr_(nullptr), del_() {}
    constexpr unique_ptr(nullptr_t) noexcept : ptr_(nullptr), del_() {}
    explicit unique_ptr(pointer p) noexcept : ptr_(p), del_() {}
    unique_ptr(pointer p, const D &d) noexcept : ptr_(p), del_(d) {}

    unique_ptr(unique_ptr &&o) noexcept
        : ptr_(o.ptr_), del_(move(o.del_)) { o.ptr_ = nullptr; }

    template <typename U, typename E>
    unique_ptr(unique_ptr<U, E> &&o) noexcept
        : ptr_(o.release()), del_(move(o.get_deleter())) {}

    unique_ptr(const unique_ptr &)            = delete;
    unique_ptr &operator=(const unique_ptr &) = delete;

    unique_ptr &operator=(unique_ptr &&o) noexcept {
        if (this != &o) {
            reset(o.ptr_);
            o.ptr_ = nullptr;
            del_ = move(o.del_);
        }
        return *this;
    }
    unique_ptr &operator=(nullptr_t) noexcept { reset(); return *this; }

    ~unique_ptr() { if (ptr_) del_(ptr_); }

    pointer release() noexcept { pointer p = ptr_; ptr_ = nullptr; return p; }

    void reset(pointer p = pointer()) noexcept {
        pointer old = ptr_;
        ptr_ = p;
        if (old) del_(old);
    }

    void swap(unique_ptr &o) noexcept {
        std::swap(ptr_, o.ptr_);
        std::swap(del_, o.del_);
    }

    pointer get() const noexcept { return ptr_; }
    D       &get_deleter() noexcept { return del_; }
    const D &get_deleter() const noexcept { return del_; }
    explicit operator bool() const noexcept { return ptr_ != nullptr; }

    T &operator*()  const { return *ptr_; }
    pointer operator->() const noexcept { return ptr_; }

private:
    pointer ptr_;
    D       del_;
};

/* --- unique_ptr (array) -------------------------------------------------- */
template <typename T, typename D>
class unique_ptr<T[], D> {
public:
    using pointer      = T *;
    using element_type = T;
    using deleter_type = D;

    constexpr unique_ptr() noexcept : ptr_(nullptr), del_() {}
    constexpr unique_ptr(nullptr_t) noexcept : ptr_(nullptr), del_() {}
    explicit unique_ptr(pointer p) noexcept : ptr_(p), del_() {}

    unique_ptr(unique_ptr &&o) noexcept
        : ptr_(o.ptr_), del_(move(o.del_)) { o.ptr_ = nullptr; }

    unique_ptr(const unique_ptr &)            = delete;
    unique_ptr &operator=(const unique_ptr &) = delete;

    unique_ptr &operator=(unique_ptr &&o) noexcept {
        if (this != &o) {
            reset(o.ptr_);
            o.ptr_ = nullptr;
            del_ = move(o.del_);
        }
        return *this;
    }
    unique_ptr &operator=(nullptr_t) noexcept { reset(); return *this; }

    ~unique_ptr() { if (ptr_) del_(ptr_); }

    pointer release() noexcept { pointer p = ptr_; ptr_ = nullptr; return p; }
    void reset(pointer p = pointer()) noexcept {
        pointer old = ptr_;
        ptr_ = p;
        if (old) del_(old);
    }
    void swap(unique_ptr &o) noexcept {
        std::swap(ptr_, o.ptr_);
        std::swap(del_, o.del_);
    }

    pointer get() const noexcept { return ptr_; }
    D       &get_deleter() noexcept { return del_; }
    const D &get_deleter() const noexcept { return del_; }
    explicit operator bool() const noexcept { return ptr_ != nullptr; }

    T &operator[](size_t i) const { return ptr_[i]; }

private:
    pointer ptr_;
    D       del_;
};

template <typename T, typename D>
bool operator==(const unique_ptr<T, D> &p, nullptr_t) noexcept { return !p; }
template <typename T, typename D>
bool operator==(nullptr_t, const unique_ptr<T, D> &p) noexcept { return !p; }
template <typename T, typename D>
bool operator!=(const unique_ptr<T, D> &p, nullptr_t) noexcept { return (bool)p; }
template <typename T, typename D>
bool operator!=(nullptr_t, const unique_ptr<T, D> &p) noexcept { return (bool)p; }

/* --- make_unique --------------------------------------------------------- */
namespace detail {
template <typename T> struct unique_if {
    using single = unique_ptr<T>;
};
template <typename T> struct unique_if<T[]> {
    using unbounded = unique_ptr<T[]>;
    using elem      = T;
};
template <typename T, size_t N> struct unique_if<T[N]> { using bounded = void; };
}

template <typename T, typename... Args>
typename detail::unique_if<T>::single make_unique(Args &&...args) {
    return unique_ptr<T>(new T(forward<Args>(args)...));
}

template <typename T>
typename detail::unique_if<T>::unbounded make_unique(size_t n) {
    return unique_ptr<T>(new typename detail::unique_if<T>::elem[n]());
}

/* --- uninitialized memory algorithms ------------------------------------- */
template <typename T, typename... Args>
T *construct_at(T *p, Args &&...args) {
    return ::new (static_cast<void *>(p)) T(forward<Args>(args)...);
}

template <typename T>
void destroy_at(T *p) { p->~T(); }

template <typename It>
void destroy(It first, It last) { for (; first != last; ++first) destroy_at(addressof(*first)); }

template <typename It, typename Size>
It destroy_n(It first, Size n) { for (; n > 0; --n, ++first) destroy_at(addressof(*first)); return first; }

template <typename In, typename Out>
Out uninitialized_copy(In first, In last, Out d) {
    using T = remove_reference_t<decltype(*d)>;
    for (; first != last; ++first, ++d) ::new (static_cast<void *>(addressof(*d))) T(*first);
    return d;
}
template <typename In, typename Size, typename Out>
Out uninitialized_copy_n(In first, Size n, Out d) {
    using T = remove_reference_t<decltype(*d)>;
    for (; n > 0; --n, ++first, ++d) ::new (static_cast<void *>(addressof(*d))) T(*first);
    return d;
}

template <typename In, typename Out>
Out uninitialized_move(In first, In last, Out d) {
    using T = remove_reference_t<decltype(*d)>;
    for (; first != last; ++first, ++d) ::new (static_cast<void *>(addressof(*d))) T(move(*first));
    return d;
}
template <typename In, typename Size, typename Out>
Out uninitialized_move_n(In first, Size n, Out d) {
    using T = remove_reference_t<decltype(*d)>;
    for (; n > 0; --n, ++first, ++d) ::new (static_cast<void *>(addressof(*d))) T(move(*first));
    return d;
}

template <typename Out, typename T>
void uninitialized_fill(Out first, Out last, const T &val) {
    using E = remove_reference_t<decltype(*first)>;
    for (; first != last; ++first) ::new (static_cast<void *>(addressof(*first))) E(val);
}
template <typename Out, typename Size, typename T>
Out uninitialized_fill_n(Out first, Size n, const T &val) {
    using E = remove_reference_t<decltype(*first)>;
    for (; n > 0; --n, ++first) ::new (static_cast<void *>(addressof(*first))) E(val);
    return first;
}

} /* namespace std */

#endif
