#ifndef VIBEOS_STRING_CXX
#define VIBEOS_STRING_CXX

/* Freestanding std::basic_string subset for VibeOS userspace.  Heap-backed,
 * always NUL-terminated, no exceptions (at()/substr trap on out-of-range).
 * The C <string.h> lives under that name and is pulled in for raw storage
 * helpers used by char_traits through <string_view>. */

#include <cstddef>
#include <new>
#include <string_view>
#include <utility>

namespace std {

template <typename CharT, typename Traits = char_traits<CharT>>
class basic_string {
public:
    using traits_type     = Traits;
    using value_type      = CharT;
    using size_type       = size_t;
    using reference       = CharT &;
    using const_reference = const CharT &;
    using pointer         = CharT *;
    using const_pointer   = const CharT *;
    using iterator        = CharT *;
    using const_iterator  = const CharT *;

    static const size_type npos = (size_type)-1;

    /* --- ctors / dtor ---------------------------------------------------- */
    basic_string() noexcept : data_(nullptr), size_(0), cap_(0) {}

    basic_string(const CharT *s) : basic_string() {
        if (s) assign_raw(s, Traits::length(s));
    }

    basic_string(const CharT *s, size_type n) : basic_string() {
        assign_raw(s, n);
    }

    basic_string(basic_string_view<CharT, Traits> sv) : basic_string() {
        assign_raw(sv.data(), sv.size());
    }

    template <typename StringLike>
    explicit basic_string(const StringLike &s) : basic_string(s.data(), s.size()) {}

    template <typename It>
    basic_string(It first, It last) : basic_string() {
        for (; first != last; ++first) push_back(*first);
    }

    basic_string(size_type n, CharT c) : basic_string() {
        ensure(n);
        for (size_type i = 0; i < n; ++i) Traits::assign(data_[i], c);
        size_ = n;
        terminate();
    }

    basic_string(const basic_string &o) : basic_string() {
        assign_raw(o.c_str(), o.size_);
    }

    basic_string(basic_string &&o) noexcept
        : data_(o.data_), size_(o.size_), cap_(o.cap_) {
        o.data_ = nullptr;
        o.size_ = 0;
        o.cap_ = 0;
    }

    ~basic_string() { ::operator delete(data_); }

    /* --- assignment ------------------------------------------------------ */
    basic_string &operator=(const basic_string &o) {
        if (this != &o) assign_raw(o.c_str(), o.size_);
        return *this;
    }

    basic_string &operator=(basic_string &&o) noexcept {
        if (this != &o) {
            ::operator delete(data_);
            data_ = o.data_;
            size_ = o.size_;
            cap_ = o.cap_;
            o.data_ = nullptr;
            o.size_ = 0;
            o.cap_ = 0;
        }
        return *this;
    }

    basic_string &operator=(const CharT *s) {
        assign_raw(s, s ? Traits::length(s) : 0);
        return *this;
    }
    basic_string &operator=(CharT c) {
        assign_raw(&c, 1);
        return *this;
    }
    template <typename StringLike>
    basic_string &operator=(const StringLike &s) {
        assign_raw(s.data(), s.size());
        return *this;
    }

    /* --- element access -------------------------------------------------- */
    reference       operator[](size_type i)       { return data_[i]; }
    const_reference operator[](size_type i) const { return c_str()[i]; }
    reference       at(size_type i)       { if (i >= size_) __builtin_trap(); return data_[i]; }
    const_reference at(size_type i) const { if (i >= size_) __builtin_trap(); return c_str()[i]; }
    reference       front()       { return data()[0]; }
    const_reference front() const { return c_str()[0]; }
    reference       back()        { return data()[size_ - 1]; }
    const_reference back()  const { return c_str()[size_ - 1]; }

    const CharT *c_str() const noexcept { return data_ ? data_ : empty_string(); }
    const CharT *data()  const noexcept { return c_str(); }
    CharT       *data()  noexcept       { ensure(0); return data_; }

    operator basic_string_view<CharT, Traits>() const noexcept {
        return basic_string_view<CharT, Traits>(c_str(), size_);
    }

    /* --- iterators ------------------------------------------------------- */
    iterator       begin() noexcept       { return data(); }
    const_iterator begin() const noexcept { return c_str(); }
    const_iterator cbegin() const noexcept { return c_str(); }
    iterator       end() noexcept         { return data() + size_; }
    const_iterator end() const noexcept   { return c_str() + size_; }
    const_iterator cend() const noexcept  { return c_str() + size_; }

    /* --- capacity -------------------------------------------------------- */
    bool      empty() const noexcept    { return size_ == 0; }
    size_type size() const noexcept     { return size_; }
    size_type length() const noexcept   { return size_; }
    size_type capacity() const noexcept { return cap_; }
    void      reserve(size_type n)      { if (n > cap_) reallocate(n); }
    void      clear() noexcept          { size_ = 0; if (data_) terminate(); }

    void resize(size_type n, CharT c = CharT()) {
        if (n > size_) {
            ensure(n);
            for (size_type i = size_; i < n; ++i) Traits::assign(data_[i], c);
        }
        size_ = n;
        terminate();
    }

    /* --- modifiers ------------------------------------------------------- */
    basic_string &append(const CharT *s, size_type n) {
        if (n == 0) return *this;
        ensure(size_ + n);
        copy_chars(data_ + size_, s, n);
        size_ += n;
        terminate();
        return *this;
    }
    basic_string &append(const CharT *s) {
        return append(s, s ? Traits::length(s) : 0);
    }
    basic_string &append(const basic_string &o) {
        return append(o.c_str(), o.size_);
    }
    basic_string &append(size_type n, CharT c) {
        ensure(size_ + n);
        for (size_type i = 0; i < n; ++i) Traits::assign(data_[size_ + i], c);
        size_ += n;
        terminate();
        return *this;
    }

    void push_back(CharT c) {
        ensure(size_ + 1);
        Traits::assign(data_[size_++], c);
        terminate();
    }
    void pop_back() {
        if (size_) {
            --size_;
            terminate();
        }
    }

    basic_string &operator+=(const basic_string &o) { return append(o); }
    basic_string &operator+=(const CharT *s)        { return append(s); }
    basic_string &operator+=(CharT c)               { push_back(c); return *this; }

    basic_string &assign(const CharT *s, size_type n) {
        assign_raw(s, n);
        return *this;
    }
    basic_string &assign(const basic_string &o) {
        assign_raw(o.c_str(), o.size_);
        return *this;
    }
    template <typename It>
    basic_string &assign(It first, It last) {
        clear();
        for (; first != last; ++first) push_back(*first);
        return *this;
    }

    /* --- operations ------------------------------------------------------ */
    basic_string substr(size_type pos = 0, size_type n = npos) const {
        if (pos > size_) __builtin_trap();
        size_type avail = size_ - pos;
        if (n > avail) n = avail;
        return basic_string(c_str() + pos, n);
    }

    int compare(const basic_string &o) const noexcept {
        size_type m = size_ < o.size_ ? size_ : o.size_;
        int r = Traits::compare(c_str(), o.c_str(), m);
        if (r) return r;
        return (size_ < o.size_) ? -1 : (size_ > o.size_ ? 1 : 0);
    }

    size_type find(CharT c, size_type pos = 0) const noexcept {
        for (size_type i = pos; i < size_; ++i) if (Traits::eq(c_str()[i], c)) return i;
        return npos;
    }

    size_type find(const CharT *s, size_type pos = 0) const noexcept {
        size_type n = Traits::length(s);
        if (n == 0) return pos <= size_ ? pos : npos;
        if (n > size_) return npos;
        for (size_type i = pos; i + n <= size_; ++i)
            if (Traits::compare(c_str() + i, s, n) == 0) return i;
        return npos;
    }

    void swap(basic_string &o) noexcept {
        CharT *d = data_; data_ = o.data_; o.data_ = d;
        size_type s = size_; size_ = o.size_; o.size_ = s;
        size_type c = cap_;  cap_  = o.cap_;  o.cap_  = c;
    }

private:
    static const CharT *empty_string() noexcept {
        static const CharT zero = CharT();
        return &zero;
    }

    void terminate() {
        if (data_) Traits::assign(data_[size_], CharT());
    }

    /* Ensure room for `need` chars plus the NUL terminator. */
    void ensure(size_type need) {
        if (data_ && need <= cap_) return;
        size_type ncap = cap_ ? cap_ * 2 : 16;
        if (ncap < need) ncap = need;
        reallocate(ncap);
    }

    void reallocate(size_type ncap) {
        CharT *nd = static_cast<CharT *>(::operator new(sizeof(CharT) * (ncap + 1)));
        if (!nd) __builtin_trap();
        for (size_type i = 0; i < size_; ++i) Traits::assign(nd[i], data_[i]);
        Traits::assign(nd[size_], CharT());
        ::operator delete(data_);
        data_ = nd;
        cap_  = ncap;
    }

    void assign_raw(const CharT *s, size_type n) {
        ensure(n);
        if (n) copy_chars(data_, s, n);
        size_ = n;
        terminate();
    }

    static void copy_chars(CharT *dst, const CharT *src, size_type n) {
        for (size_type i = 0; i < n; ++i) Traits::assign(dst[i], src[i]);
    }

    CharT    *data_;
    size_type size_;
    size_type cap_;
};

using string = basic_string<char>;

inline string to_string(long long v) {
    bool neg = v < 0;
    unsigned long long n = neg ? (unsigned long long)(-v) : (unsigned long long)v;
    char tmp[32];
    size_t i = 0;
    do { tmp[i++] = (char)('0' + (n % 10)); n /= 10; } while (n);
    string out;
    if (neg) out.push_back('-');
    while (i) out.push_back(tmp[--i]);
    return out;
}
inline string to_string(unsigned long long v) {
    char tmp[32];
    size_t i = 0;
    do { tmp[i++] = (char)('0' + (v % 10)); v /= 10; } while (v);
    string out;
    while (i) out.push_back(tmp[--i]);
    return out;
}
inline string to_string(int v) { return to_string((long long)v); }
inline string to_string(unsigned v) { return to_string((unsigned long long)v); }
inline string to_string(long v) { return to_string((long long)v); }
inline string to_string(unsigned long v) { return to_string((unsigned long long)v); }

/* --- non-member operators ------------------------------------------------ */
template <typename C, typename T>
basic_string<C, T> operator+(const basic_string<C, T> &a, const basic_string<C, T> &b) {
    basic_string<C, T> r(a); r.append(b); return r;
}
template <typename C, typename T>
basic_string<C, T> operator+(const basic_string<C, T> &a, const C *b) {
    basic_string<C, T> r(a); r.append(b); return r;
}
template <typename C, typename T>
basic_string<C, T> operator+(const C *a, const basic_string<C, T> &b) {
    basic_string<C, T> r(a); r.append(b); return r;
}
template <typename C, typename T>
basic_string<C, T> operator+(const basic_string<C, T> &a, C b) {
    basic_string<C, T> r(a); r.push_back(b); return r;
}

template <typename C, typename T>
bool operator==(const basic_string<C, T> &a, const basic_string<C, T> &b) noexcept { return a.compare(b) == 0; }
template <typename C, typename T>
bool operator!=(const basic_string<C, T> &a, const basic_string<C, T> &b) noexcept { return a.compare(b) != 0; }
template <typename C, typename T>
bool operator< (const basic_string<C, T> &a, const basic_string<C, T> &b) noexcept { return a.compare(b) <  0; }
template <typename C, typename T>
bool operator> (const basic_string<C, T> &a, const basic_string<C, T> &b) noexcept { return a.compare(b) >  0; }
template <typename C, typename T>
bool operator<=(const basic_string<C, T> &a, const basic_string<C, T> &b) noexcept { return a.compare(b) <= 0; }
template <typename C, typename T>
bool operator>=(const basic_string<C, T> &a, const basic_string<C, T> &b) noexcept { return a.compare(b) >= 0; }

template <typename C, typename T>
bool operator==(const basic_string<C, T> &a, const C *b) noexcept {
    return a.compare(basic_string<C, T>(b)) == 0;
}
template <typename C, typename T>
bool operator==(const C *a, const basic_string<C, T> &b) noexcept {
    return basic_string<C, T>(a).compare(b) == 0;
}
template <typename C, typename T>
bool operator!=(const basic_string<C, T> &a, const C *b) noexcept { return !(a == b); }
template <typename C, typename T>
bool operator!=(const C *a, const basic_string<C, T> &b) noexcept { return !(a == b); }

} /* namespace std */

#endif
