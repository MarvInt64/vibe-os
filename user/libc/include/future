#ifndef VIBEOS_FUTURE
#define VIBEOS_FUTURE

#include <type_traits>
#include <utility>

namespace std {

enum class launch { async = 1, deferred = 2 };

template <typename T> class shared_future;

template <typename T>
class future {
public:
    future() : ready_(false), value_(), ref_(&value_) {}
    explicit future(T v) : ready_(true), value_(move(v)), ref_(&value_) {}
    explicit future(T *ref) : ready_(false), value_(), ref_(ref) {}
    void wait() const {}
    T get() { ready_ = true; return move(*ref_); }
    shared_future<T> share() { return shared_future<T>(*ref_); }
private:
    bool ready_;
    T value_;
    T *ref_;
};

template <>
class future<void> {
public:
    future() = default;
    void wait() const {}
    void get() {}
    shared_future<void> share();
};

template <typename T>
class shared_future {
public:
    shared_future() : value_() {}
    explicit shared_future(T v) : value_(move(v)) {}
    void wait() const {}
    T get() const { return value_; }
private:
    T value_;
};

template <>
class shared_future<void> {
public:
    void wait() const {}
    void get() const {}
};

inline shared_future<void> future<void>::share() { return shared_future<void>(); }

template <typename T>
class promise {
public:
    promise() : value_() {}
    promise(const promise &) = delete;
    promise &operator=(const promise &) = delete;

    future<T> get_future() { return future<T>(&value_); }

    template <typename U>
    void set_value(U &&v) { value_ = forward<U>(v); }

private:
    T value_;
};

template <>
class promise<void> {
public:
    promise() = default;
    promise(const promise &) = delete;
    promise &operator=(const promise &) = delete;

    future<void> get_future() { return future<void>(); }
    void set_value() {}
};

template <typename F>
auto async(launch, F &&f) -> future<decltype(f())> {
    using R = decltype(f());
    if constexpr (is_void<R>::value) {
        f();
        return future<void>();
    } else {
        return future<R>(f());
    }
}

template <typename F>
auto async(F &&f) -> future<decltype(f())> {
    return async(launch::deferred, forward<F>(f));
}

} /* namespace std */

#endif
