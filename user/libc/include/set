#ifndef VIBEOS_SET
#define VIBEOS_SET

/* Freestanding std::set subset for VibeOS userspace.  Ordered unique-key
 * container backed by a sorted std::vector<Key> with binary search — O(log n)
 * lookup, O(n) insert/erase (effectively a flat_set; insert/erase invalidate
 * iterators).  Reuses the verified <vector>, so it is robust. */

#include <cstddef>
#include <utility>
#include <functional>
#include <vector>
#include <initializer_list>

namespace std {

template <typename Key, typename Compare = less<Key>>
class set {
public:
    using key_type       = Key;
    using value_type     = Key;
    using size_type      = size_t;
    using iterator       = typename vector<Key>::const_iterator;
    using const_iterator = typename vector<Key>::const_iterator;

    set() = default;
    set(const set &) = default;
    set(set &&) noexcept = default;
    set &operator=(const set &) = default;
    set &operator=(set &&) noexcept = default;

    set(initializer_list<Key> il) { for (const Key &k : il) insert(k); }
    template <typename It>
    set(It first, It last) { for (; first != last; ++first) insert(*first); }

    const_iterator begin() const noexcept { return data_.begin(); }
    const_iterator end()   const noexcept { return data_.end(); }
    const_iterator cbegin() const noexcept { return data_.begin(); }
    const_iterator cend()   const noexcept { return data_.end(); }

    bool      empty() const noexcept { return data_.empty(); }
    size_type size() const noexcept  { return data_.size(); }
    void      clear() noexcept       { data_.clear(); }

    const_iterator find(const Key &k) const {
        size_type lo = lower(k);
        if (lo < data_.size() && eq(data_[lo], k)) return data_.begin() + lo;
        return data_.end();
    }
    size_type count(const Key &k) const { return find(k) == end() ? 0 : 1; }
    bool contains(const Key &k) const { return find(k) != end(); }

    const_iterator lower_bound(const Key &k) const { return data_.begin() + lower(k); }
    const_iterator upper_bound(const Key &k) const {
        size_type lo = lower(k);
        if (lo < data_.size() && eq(data_[lo], k)) ++lo;
        return data_.begin() + lo;
    }

    pair<const_iterator, bool> insert(const Key &k) {
        size_type lo = lower(k);
        if (lo < data_.size() && eq(data_[lo], k))
            return { data_.begin() + lo, false };
        data_.insert(data_.begin() + lo, k);
        return { data_.begin() + lo, true };
    }
    pair<const_iterator, bool> insert(Key &&k) {
        size_type lo = lower(k);
        if (lo < data_.size() && eq(data_[lo], k))
            return { data_.begin() + lo, false };
        data_.insert(data_.begin() + lo, move(k));
        return { data_.begin() + lo, true };
    }

    template <typename... Args>
    pair<const_iterator, bool> emplace(Args &&...args) {
        return insert(Key(forward<Args>(args)...));
    }

    size_type erase(const Key &k) {
        size_type lo = lower(k);
        if (lo < data_.size() && eq(data_[lo], k)) {
            data_.erase(data_.begin() + lo);
            return 1;
        }
        return 0;
    }

    void swap(set &o) noexcept { data_.swap(o.data_); }

private:
    size_type lower(const Key &k) const {
        size_type lo = 0, hi = data_.size();
        while (lo < hi) {
            size_type mid = lo + (hi - lo) / 2;
            if (comp_(data_[mid], k)) lo = mid + 1;
            else                      hi = mid;
        }
        return lo;
    }
    bool eq(const Key &a, const Key &b) const { return !comp_(a, b) && !comp_(b, a); }

    vector<Key> data_;
    Compare     comp_{};
};

} /* namespace std */

#endif
