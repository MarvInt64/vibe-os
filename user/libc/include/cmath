#ifndef VIBEOS_CMATH
#define VIBEOS_CMATH

namespace std {

inline int vibeos_abs(int x) { return x < 0 ? -x : x; }
inline long vibeos_abs(long x) { return x < 0 ? -x : x; }
inline long long vibeos_abs(long long x) { return x < 0 ? -x : x; }
inline double fabs(double x) { return x < 0 ? -x : x; }
inline float fabs(float x) { return x < 0 ? -x : x; }
inline long double fabs(long double x) { return x < 0 ? -x : x; }
inline double floor(double x) { return __builtin_floor(x); }
inline double ceil(double x) { return __builtin_ceil(x); }
inline double sqrt(double x) { return __builtin_sqrt(x); }
inline double modf(double x, double *iptr) { return __builtin_modf(x, iptr); }
inline bool isfinite(double x) { return __builtin_isfinite(x); }
inline bool isinf(double x) { return __builtin_isinf(x); }
inline bool isnan(double x) { return __builtin_isnan(x); }
} /* namespace std */

#endif
