#ifndef VIBEOS_MAP
#define VIBEOS_MAP

/* Freestanding std::map subset for VibeOS userspace.  Ordered associative
 * container backed by a sorted std::vector<pair<const-ish Key, T>> with binary
 * search — O(log n) lookup, O(n) insert/erase.  This reuses the verified
 * <vector>, so it is robust; the trade-off vs a real red-black tree is that
 * insert()/erase() invalidate iterators (a sorted-vector flat_map, in effect).
 * No exceptions: at() on a missing key traps via __builtin_trap(). */

#include <cstddef>
#include <type_traits>
#include <utility>
#include <functional>
#include <vector>

namespace std {

template <typename Key, typename T, typename Compare = less<Key>>
class map {
public:
    using key_type    = Key;
    using mapped_type = T;
    using value_type  = pair<Key, T>;
    using size_type   = size_t;
    using iterator       = typename vector<value_type>::iterator;
    using const_iterator = typename vector<value_type>::const_iterator;

    map() = default;
    map(const map &) = default;
    map(map &&) noexcept = default;
    map &operator=(const map &) = default;
    map &operator=(map &&) noexcept = default;

    map(initializer_list<value_type> il) {
        for (const value_type &kv : il) insert(kv);
    }

    /* --- iterators (sorted order) ---------------------------------------- */
    iterator       begin() noexcept       { return data_.begin(); }
    const_iterator begin() const noexcept { return data_.begin(); }
    iterator       end() noexcept         { return data_.end(); }
    const_iterator end() const noexcept   { return data_.end(); }

    /* --- capacity -------------------------------------------------------- */
    bool      empty() const noexcept { return data_.empty(); }
    size_type size() const noexcept  { return data_.size(); }
    void      clear() noexcept       { data_.clear(); }

    /* --- lookup ---------------------------------------------------------- */
    template <typename K>
    iterator find(const K &k) {
        size_type lo = lower(k);
        if (lo < data_.size() && key_eq(data_[lo].first, k)) return data_.begin() + lo;
        return data_.end();
    }
    template <typename K>
    const_iterator find(const K &k) const {
        size_type lo = lower(k);
        if (lo < data_.size() && key_eq(data_[lo].first, k)) return data_.begin() + lo;
        return data_.end();
    }
    size_type count(const Key &k) const { return find(k) == end() ? 0 : 1; }
    bool contains(const Key &k) const { return find(k) != end(); }

    template <typename K>
    iterator lower_bound(const K &k) { return data_.begin() + lower(k); }
    template <typename K>
    const_iterator lower_bound(const K &k) const { return data_.begin() + lower(k); }
    template <typename K>
    iterator upper_bound(const K &k) {
        size_type lo = lower(k);
        if (lo < data_.size() && key_eq(data_[lo].first, k)) ++lo;
        return data_.begin() + lo;
    }
    template <typename K>
    const_iterator upper_bound(const K &k) const {
        size_type lo = lower(k);
        if (lo < data_.size() && key_eq(data_[lo].first, k)) ++lo;
        return data_.begin() + lo;
    }

    T &at(const Key &k) {
        size_type lo = lower(k);
        if (lo >= data_.size() || !key_eq(data_[lo].first, k)) __builtin_trap();
        return data_[lo].second;
    }
    const T &at(const Key &k) const {
        size_type lo = lower(k);
        if (lo >= data_.size() || !key_eq(data_[lo].first, k)) __builtin_trap();
        return data_[lo].second;
    }

    T &operator[](const Key &k) {
        size_type lo = lower(k);
        if (lo < data_.size() && key_eq(data_[lo].first, k)) return data_[lo].second;
        data_.insert(data_.begin() + lo, value_type(k, T()));
        return data_[lo].second;
    }

    /* --- modifiers ------------------------------------------------------- */
    pair<iterator, bool> insert(const value_type &kv) {
        size_type lo = lower(kv.first);
        if (lo < data_.size() && key_eq(data_[lo].first, kv.first))
            return { data_.begin() + lo, false };
        data_.insert(data_.begin() + lo, kv);
        return { data_.begin() + lo, true };
    }

    iterator insert(const_iterator, const value_type &kv) {
        return insert(kv).first;
    }

    template <typename... Args>
    pair<iterator, bool> emplace(const Key &k, Args &&...args) {
        size_type lo = lower(k);
        if (lo < data_.size() && key_eq(data_[lo].first, k))
            return { data_.begin() + lo, false };
        data_.insert(data_.begin() + lo, value_type(k, T(forward<Args>(args)...)));
        return { data_.begin() + lo, true };
    }

    template <typename K, typename... Args>
    pair<iterator, bool> try_emplace(K &&k, Args &&...args) {
        size_type lo = lower(k);
        if (lo < data_.size() && key_eq(data_[lo].first, k))
            return { data_.begin() + lo, false };
        data_.insert(data_.begin() + lo,
                     value_type(forward<K>(k), T(forward<Args>(args)...)));
        return { data_.begin() + lo, true };
    }

    size_type erase(const Key &k) {
        size_type lo = lower(k);
        if (lo < data_.size() && key_eq(data_[lo].first, k)) {
            data_.erase(data_.begin() + lo);
            return 1;
        }
        return 0;
    }

    iterator erase(const_iterator pos) {
        size_type idx = (size_type)(pos - data_.begin());
        return data_.erase(data_.begin() + idx);
    }

    void swap(map &o) noexcept { data_.swap(o.data_); }

private:
    /* First index i with !comp(data_[i].first, k)  (binary search). */
    template <typename K>
    size_type lower(const K &k) const {
        size_type lo = 0, hi = data_.size();
        while (lo < hi) {
            size_type mid = lo + (hi - lo) / 2;
            if (comp_(data_[mid].first, k)) lo = mid + 1;
            else                            hi = mid;
        }
        return lo;
    }
    template <typename A, typename B>
    bool key_eq(const A &a, const B &b) const {
        return !comp_(a, b) && !comp_(b, a);
    }

    vector<value_type> data_;
    Compare            comp_{};
};

template <typename K, typename T, typename C>
bool operator==(const map<K, T, C> &a, const map<K, T, C> &b) {
    if (a.size() != b.size()) return false;
    auto ia = a.begin();
    auto ib = b.begin();
    for (; ia != a.end(); ++ia, ++ib) if (!(*ia == *ib)) return false;
    return true;
}
template <typename K, typename T, typename C>
bool operator!=(const map<K, T, C> &a, const map<K, T, C> &b) { return !(a == b); }
template <typename K, typename T, typename C>
bool operator<(const map<K, T, C> &a, const map<K, T, C> &b) {
    auto ia = a.begin();
    auto ib = b.begin();
    for (; ia != a.end() && ib != b.end(); ++ia, ++ib) {
        if (*ia < *ib) return true;
        if (*ib < *ia) return false;
    }
    return ia == a.end() && ib != b.end();
}

template <typename Key, typename T, typename Compare = less<Key>>
class multimap : public map<Key, T, Compare> {
public:
    using map<Key, T, Compare>::map;
    using typename map<Key, T, Compare>::iterator;
    using typename map<Key, T, Compare>::const_iterator;
    pair<iterator, iterator> equal_range(const Key &k) {
        auto it = this->find(k);
        return {it, it == this->end() ? it : it + 1};
    }
    pair<const_iterator, const_iterator> equal_range(const Key &k) const {
        auto it = this->find(k);
        return {it, it == this->end() ? it : it + 1};
    }
};

} /* namespace std */

#endif
